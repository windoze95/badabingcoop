# /etc/badabing/badabing-status.env
# Tunables for the Bada Bing coop status reporter.
# Sourced by /usr/local/bin/badabing-status.sh (via the systemd unit's EnvironmentFile).
# Edit values here, then: sudo systemctl restart badabing-status.timer
# -----------------------------------------------------------------------------

# --- Where to push status.json (over the WireGuard tunnel) -------------------
# DEPLOY_HOST is the droplet's IN-TUNNEL WireGuard address (10.10.0.1), NOT its
# public IP. The Pi (10.10.0.2) pushes outbound only; nothing inbound reaches
# the home network. DEPLOY_USER is the locked-down deploy account on the droplet
# whose authorized_keys forces rrsync onto /var/www/badabing/api ONLY.
# NOTE: 10.10.0.1 matches this repo's existing WireGuard scheme (droplet wg0.conf
# Address=10.10.0.1/24, Pi AllowedIPs=10.10.0.1/32). The Pi's wg AllowedIPs only
# routes 10.10.0.1/32, so this is the one in-tunnel host it can reach.
DEPLOY_USER=coopstatus
DEPLOY_HOST=10.10.0.1
DEPLOY_SSH_PORT=22

# Private key for the deploy account. Keep it 0600, owned by root (the service
# runs as root to read sensors); its PUBLIC half lives in coopstatus's
# authorized_keys on the droplet behind the rrsync forced-command.
DEPLOY_SSH_KEY=/etc/badabing/keys/coopstatus_ed25519

# Path RELATIVE to the rrsync-locked root (/var/www/badabing/api). "." = that dir.
# Leave as "." unless you also lock a deeper subdir in the forced-command.
DEPLOY_REMOTE_PATH=.

# --- Local staging -----------------------------------------------------------
# tmpfs is ideal (no SD-card wear). /run is tmpfs on Raspberry Pi OS.
STAGE_DIR=/run/badabing

# --- Jukebox now-playing source ----------------------------------------------
# File the jukebox (badabing-nowplaying.service) updates with the current track.
# This reporter auto-detects the format: the project's MPD JSON
# {composer,piece,album,state,...} (state=play/pause/stopped), a generic
# {artist,title,playing} object, or a plain "Artist - Title" line.
# MUST match NOWPLAYING_JSON in badabing-music.env (default /run/badabing/nowplaying.json).
# Set empty to omit the music field.
NOWPLAYING_FILE=/run/badabing/nowplaying.json

# --- Stream freshness --------------------------------------------------------
# The unit whose active state indicates the camera pipeline is running.
STREAM_UNIT=badabing-stream.service
# OPTIONAL: a file whose mtime tracks the last delivered frame. If you touch this
# from the stream pipeline you get a true last-frame age; otherwise the reporter
# falls back to the unit's active state. Comment out to disable.
FRAME_TOUCH_FILE=/run/badabing/last-frame
# Max seconds since last frame that still counts as "up".
FRAME_MAX_AGE=30

# --- WiFi --------------------------------------------------------------------
WIFI_IFACE=wlan0

# --- Battery telemetry via INA219 (OPTIONAL) ---------------------------------
# Leave 0 to disable entirely (status.json will report battery: null and no I2C
# is touched). Set to 1 ONLY if an INA219 is wired to the Pi's I2C pins AND
# smbus2 is installed (sudo apt install -y python3-smbus2) AND I2C is enabled.
BATTERY_ENABLE=0
# I2C bus + 7-bit address (0x40 with both A0/A1 pins to GND).
INA219_BUS=1
INA219_ADDR=0x40
# Shunt resistor on the breakout (Adafruit/most clones = 0.1 ohm).
INA219_SHUNT_OHMS=0.1
# Max expected current (A) — sizes the ADC range.
INA219_MAX_AMPS=3.0
# LiFePO4 resting-voltage window for the rough SoC percentage. Defaults assume a
# 4S (4-cell) LiFePO4 pack: ~13.4V full, ~12.0V near-empty. TUNE to your pack.
BATT_FULL_V=13.4
BATT_EMPTY_V=12.0
# Reader CLI (bundled). Override only if you install it elsewhere.
INA219_READER=/usr/local/bin/badabing-ina219.py
