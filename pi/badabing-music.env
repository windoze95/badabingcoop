# /etc/badabing/badabing-music.env
# Tunables for the Bada Bing coop "classical-over-Bluetooth" music subsystem.
# Sourced by the music helper scripts and referenced by the systemd units.
# Edit values here, then: sudo systemctl restart badabing-bt-connect.service
#                         sudo systemctl restart mpd.service
# -----------------------------------------------------------------------------

# --- Bluetooth speaker -------------------------------------------------------
# MAC address of YOUR Bluetooth speaker. Find it with `bluetoothctl scan on`
# (the speaker must be in pairing mode). Format AA:BB:CC:DD:EE:FF, uppercase.
# This is the speaker we pair, trust, and auto-reconnect to.
BT_SPEAKER_MAC=AA:BB:CC:DD:EE:FF

# Friendly name (informational only; used in log lines).
BT_SPEAKER_NAME=BadaBing Speaker

# Which Bluetooth controller (hciX) to use.
# IMPORTANT (coexistence): on the Pi Zero 2 W the ON-BOARD Bluetooth shares the
# single 2.4 GHz radio with Wi-Fi, and this Pi is ALSO pushing H.264 over Wi-Fi
# 24/7 — that combination makes on-board A2DP stutter badly (see notes in
# badabing-bt-setup.sh). The strongly-recommended fix is a USB Bluetooth dongle
# on its OWN controller, so music never competes with the camera's Wi-Fi.
#
# WHICH hciX IS THE DONGLE? It depends on whether on-board BT is disabled:
#   - power-tune's `dtoverlay=disable-bt` is ACTIVE (recommended with a dongle):
#       the on-board radio is gone, so the dongle is the ONLY controller -> hci0.
#   - on-board BT still enabled AND a dongle plugged in:
#       the dongle is usually hci1 (on-board is hci0) — but enumeration order is
#       NOT guaranteed across reboots, so VERIFY with `bluetoothctl list` and the
#       dongle's printed MAC. The scripts resolve hciX -> controller MAC, so as
#       long as BT_CONTROLLER names the right adapter the connect targets it.
#   - on-board only (NOT recommended on this build):  hci0
#
# DEFAULT below is hci0 to match the recommended disable-bt + USB-dongle path
# (dongle = sole controller = hci0). Change to hci1 only if you keep on-board BT.
BT_CONTROLLER=hci0

# A2DP codec hint. SBC is universal; sbc-xq is higher quality and supported by
# most modern speakers. Leave as sbc-xq and WirePlumber will fall back to sbc if
# the speaker refuses it. (LDAC/aptX only if the speaker advertises them.)
BT_CODEC=sbc-xq

# --- Music library -----------------------------------------------------------
# Root of the local music library MPD scans and shuffles. Drop your own
# .mp3/.flac/.ogg/.opus files anywhere under here (subfolders are fine) and run
# `mpc update` — see fetch-music.sh for the auto-download option.
MUSIC_DIR=/srv/badabing/music

# --- Now-playing output ------------------------------------------------------
# Where the now-playing writer emits the current composer + piece. /run is a
# tmpfs (RAM) so we never wear the SD card writing this every track. Other
# scripts (e.g. an on-screen overlay on the video, a web widget) read these.
NOWPLAYING_DIR=/run/badabing
NOWPLAYING_TXT=/run/badabing/nowplaying.txt
NOWPLAYING_JSON=/run/badabing/nowplaying.json
