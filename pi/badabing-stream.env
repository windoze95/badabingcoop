# /etc/badabing/badabing-stream.env
# Tunables for the Bada Bing coop camera stream.
# Sourced by /usr/local/bin/badabing-stream.sh (via the systemd unit's EnvironmentFile).
# Edit values here, then: sudo systemctl restart badabing-stream.service
# -----------------------------------------------------------------------------

# --- Remote MediaMTX target (reached over the WireGuard tunnel) ---------------
# WG_IP is the MediaMTX server's address INSIDE the WireGuard tunnel (the wg0
# peer address of the droplet), NOT its public IP. The Pi is behind home NAT
# and can only push outbound, so all RTSP traffic rides the tunnel.
# MUST match the droplet's [Interface] Address in wg0.conf (10.10.0.1) and
# mediamtx.yml rtspAddress (10.10.0.1:8554).
WG_IP=10.10.0.1
RTSP_PORT=8554
# MUST match the path name in the droplet's mediamtx.yml (coop), the nginx
# location (/coop/), and app.js streamPath ("coop"). All four must agree.
MTX_PATH=coop

# RTSP transport. Use tcp for reliability over the tunnel (UDP RTP loss on a
# residential uplink shows up as macroblocking / stream stalls). MediaMTX
# accepts TCP publishers on the same 8554 port.
RTSP_TRANSPORT=tcp

# Publish credentials. REQUIRED: the droplet's mediamtx.yml defines an
# authInternalUsers entry "chickenpi" with action: publish on the "coop"
# path (NOT "chickencam"), so an unauthenticated push will be REJECTED. These
# are injected as
# user:pass@ in the RTSP URL. RTSP_PASS must be the PLAINTEXT password whose
# sha256: hash is stored server-side (the client always sends the plaintext;
# MediaMTX hashes and compares).
RTSP_USER=chickenpi
RTSP_PASS=REPLACE_WITH_PI_PUBLISH_PASSWORD

# --- Capture / encode settings -----------------------------------------------
# 1280x720 @ 15 fps is the sweet spot for a ~2.5 W solar budget on a Pi Zero 2 W:
# it keeps the hardware H.264 encoder lightly loaded, halves the per-second
# encode work vs 30 fps, and fits comfortably in a modest residential uplink.
# Bump to 30 fps only if your panel/battery and upload can sustain it.
WIDTH=1280
HEIGHT=720
FRAMERATE=15

# Encoder bitrate in BITS PER SECOND (rpicam-vid --bitrate unit).
# 1.5 Mbps is plenty for a mostly-static coop scene at 720p15 and leaves
# headroom on a typical 5-10 Mbps residential upload (keep target <= ~60% of
# measured upload to survive jitter). Range to consider: 1000000-2500000.
BITRATE=1500000

# Keyframe (intra) interval in FRAMES. One keyframe per second
# (= FRAMERATE) gives MediaMTX/readers a fast join point and bounds the
# damage from a dropped packet without inflating bitrate much.
# This is passed to rpicam-vid --intra.
INTRA=15

# H.264 profile/level. "high" + 4.1 is broadly compatible and efficient.
H264_PROFILE=high
H264_LEVEL=4.1

# Image orientation. Set to 1 to enable. Coop camera is often mounted inverted.
HFLIP=0
VFLIP=0
# Rotation must be 0 or 180 on the Pi ISP (90/270 are not supported in-pipe).
ROTATION=0

# Denoise mode. cdn_off disables colour denoise to save a little CPU/power;
# use "auto" if low-light noise is objectionable. Other values: cdn_fast, cdn_hq.
DENOISE=cdn_off

# Auto-focus mode for Camera Module 3 (which has motorised AF).
# "manual" + fixed lens position is lowest-power and most stable for a fixed
# scene; the AF motor never hunts. Set AF_MODE=continuous to let it refocus.
AF_MODE=manual
# Lens position in dioptres when AF_MODE=manual. 0 = infinity. ~2-3 m focus for
# a coop is roughly 0.3-0.5; tune by eye. Ignored unless AF_MODE=manual.
LENS_POSITION=0.4

# Auto white balance preset. "daylight" is stable outdoors; "auto" adapts but
# can shift colour through the day. Other values: cloudy, tungsten, fluorescent.
AWB=daylight

# Which camera index to use (relevant only if more than one is attached).
CAMERA=0
