# =============================================================================
# The Bada Bing — MASTER reference of every operator-supplied value.
#
# This file is DOCUMENTATION, not a runtime config. The project does not source
# a single .env at runtime; instead each value below ultimately lives in one or
# more concrete files (Terraform tfvars, the droplet cloud-init / mediamtx.yml /
# nginx, or the Pi's /etc/badabing/*.env). This file is the one place that lists
# EVERY placeholder you must fill and tells you EXACTLY where each one goes.
#
# Workflow:
#   cp .env.example .env        # (your real .env is gitignored)
#   fill the values below, then propagate each one into the file(s) named in its
#   comment — or, with Terraform, set the matching TF_VAR_* / tfvars and let
#   templatefile(user-data.tftpl) inject them for you.
#
# All values here are PLACEHOLDERS. Do not commit a filled copy.
# =============================================================================


# -----------------------------------------------------------------------------
# DOMAIN / TLS
# -----------------------------------------------------------------------------

# Public hostname that points (DNS A/AAAA) at the droplet's reserved IP.
# GOES INTO:
#   * droplet/terraform/terraform.tfvars        (domain)
#   * droplet/nginx/coop.conf                    (server_name + ssl_certificate paths)
#   * droplet/cloud-init/cloud-init.yaml         (server_name + cert paths + certbot -d)
#   * droplet/mediamtx/mediamtx.yml              (reference only; media uses the IP)
DOMAIN=cam.example.com

# Email for Let's Encrypt / certbot registration + expiry notices.
# GOES INTO:
#   * droplet/terraform/terraform.tfvars        (admin_email)
#   * droplet/cloud-init/cloud-init.yaml         (certbot -m REPLACE_WITH_YOUR_EMAIL)
ACME_EMAIL=REPLACE_WITH_YOUR_EMAIL


# -----------------------------------------------------------------------------
# DigitalOcean / Terraform
# -----------------------------------------------------------------------------

# DigitalOcean API token (Settings -> API -> Tokens). Treat as a SECRET.
# GOES INTO:
#   * droplet/terraform/terraform.tfvars        (do_token)  — or export TF_VAR_do_token
DO_TOKEN=dop_v1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DO region slug (closest to most viewers AND your home, for WireGuard RTT).
# GOES INTO: droplet/terraform/terraform.tfvars (region)
DO_REGION=nyc3

# Droplet size slug. s-1vcpu-1gb is plenty (MediaMTX remuxes, does not transcode).
# GOES INTO: droplet/terraform/terraform.tfvars (droplet_size)
DO_DROPLET_SIZE=s-1vcpu-1gb

# Fingerprints of SSH keys already uploaded to your DO account.
#   doctl compute ssh-key list
# GOES INTO: droplet/terraform/terraform.tfvars (ssh_key_fingerprints, a LIST)
DO_SSH_KEY_FINGERPRINT=aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99

# Your SSH PUBLIC key contents (the ssh-ed25519 AAAA... line).
# GOES INTO:
#   * droplet/terraform/terraform.tfvars        (ssh_public_key)
#   * droplet/cloud-init/cloud-init.yaml         (REPLACE_WITH_YOUR_SSH_PUBLIC_KEY)
SSH_PUBLIC_KEY=REPLACE_WITH_YOUR_SSH_PUBLIC_KEY

# The droplet's stable reserved (floating) IP. With Terraform this is CREATED for
# you (digitalocean_reserved_ip.cam) and injected automatically; for a manual
# deploy you fill it after the IP is allocated.
# GOES INTO:
#   * droplet/mediamtx/mediamtx.yml              (webrtcAdditionalHosts — the IP LITERAL)
#   * droplet/cloud-init/cloud-init.yaml         (REPLACE_WITH_DROPLET_RESERVED_IP)
#   * the Pi's WireGuard Endpoint (pi/install.sh / wg0-pi.conf.example: Endpoint = IP:51820)
DROPLET_RESERVED_IP=REPLACE_WITH_DROPLET_RESERVED_IP

# CIDRs allowed to reach SSH (22). Lock this to your IP for real security.
# GOES INTO: droplet/terraform/terraform.tfvars (ssh_admin_source_addresses, a LIST)
SSH_ADMIN_SOURCE_ADDRESSES=0.0.0.0/0


# -----------------------------------------------------------------------------
# WireGuard keys  (generate with `make gen-keys`; NEVER reuse the placeholders)
#   wg genkey | tee server_private.key | wg pubkey > server_public.key
#   wg genkey | tee pi_private.key     | wg pubkey > pi_public.key
#   wg genpsk  > preshared.key          (optional, recommended)
# Topology: droplet 10.10.0.1/24  <->  Pi 10.10.0.2/32 ; ListenPort 51820/udp.
# -----------------------------------------------------------------------------

# Droplet (server) PRIVATE key — stays on the droplet only.
# GOES INTO:
#   * droplet/wireguard/wg0.conf                 ([Interface] PrivateKey)
#   * droplet/terraform/terraform.tfvars        (wg_server_private_key)
#   * droplet/cloud-init/cloud-init.yaml         (REPLACE_WITH_SERVER_PRIVATE_KEY)
WG_SERVER_PRIVATE_KEY=REPLACE_WITH_SERVER_PRIVATE_KEY

# Pi (peer) PUBLIC key — the droplet authorizes this peer.
# GOES INTO:
#   * droplet/wireguard/wg0.conf                 ([Peer] PublicKey)
#   * droplet/terraform/terraform.tfvars        (wg_pi_public_key)
#   * droplet/cloud-init/cloud-init.yaml         (REPLACE_WITH_PI_PUBLIC_KEY)
WG_PI_PUBLIC_KEY=REPLACE_WITH_PI_PUBLIC_KEY

# Pi (peer) PRIVATE key — stays on the Pi only.
# GOES INTO: the Pi's /etc/wireguard/wg0.conf ([Interface] PrivateKey;
#            see droplet/wireguard/wg0-pi.conf.example).
WG_PI_PRIVATE_KEY=REPLACE_WITH_PI_PRIVATE_KEY

# Droplet (server) PUBLIC key — the Pi authorizes this peer.
# GOES INTO: the Pi's /etc/wireguard/wg0.conf ([Peer] PublicKey).
WG_SERVER_PUBLIC_KEY=REPLACE_WITH_SERVER_PUBLIC_KEY

# OPTIONAL pre-shared key (extra symmetric hardening on BOTH ends).
# GOES INTO: droplet wg0.conf [Peer] PresharedKey  AND  Pi wg0.conf [Peer] PresharedKey.
WG_PRESHARED_KEY=REPLACE_WITH_PRESHARED_KEY


# -----------------------------------------------------------------------------
# MediaMTX publish credentials  (the ONLY authenticated party in the pipeline)
# The Pi authenticates to PUBLISH the "coop" path over WireGuard. Viewers are
# anonymous (the viewer is PUBLIC by design).
# -----------------------------------------------------------------------------

# Fixed publish username. Must match across all three files below.
# GOES INTO:
#   * droplet/mediamtx/mediamtx.yml              (authInternalUsers: user: chickenpi)
#   * pi/badabing-stream.env                     (RTSP_USER)
PI_PUBLISH_USER=chickenpi

# Publish PASSWORD (plaintext). The Pi sends plaintext; MediaMTX may store it as
# a sha256: hash. Generate the hash with:  printf '%s' "$PASS" | sha256sum
# GOES INTO:
#   * pi/badabing-stream.env                     (RTSP_PASS — PLAINTEXT)
#   * droplet/mediamtx/mediamtx.yml              (authInternalUsers pass: — plaintext OR "sha256:<hash>")
#   * droplet/terraform/terraform.tfvars        (pi_publish_password)
#   * droplet/cloud-init/cloud-init.yaml         (REPLACE_WITH_PI_PUBLISH_PASSWORD)
PI_PUBLISH_PASSWORD=REPLACE_WITH_PI_PUBLISH_PASSWORD


# -----------------------------------------------------------------------------
# OPT-IN viewer Basic Auth  (the viewer is PUBLIC by default — leave this unset)
# Only relevant if you re-enable the commented-out auth_basic block in
# droplet/nginx/coop.conf and create an htpasswd file.
# -----------------------------------------------------------------------------

# GOES INTO (only if you opt in): /etc/nginx/.htpasswd_coop via
#   htpasswd -bc /etc/nginx/.htpasswd_coop viewer "$VIEWER_PASSWORD"
# (Also referenced by droplet/terraform variable viewer_password, which exists
#  for the opt-in path; unused while the viewer is public.)
VIEWER_PASSWORD=change-me-only-if-you-opt-into-basic-auth


# -----------------------------------------------------------------------------
# Bluetooth jukebox  (OPTIONAL — only the --jukebox Pi install uses these)
# -----------------------------------------------------------------------------

# MAC of YOUR Bluetooth speaker (uppercase AA:BB:CC:DD:EE:FF). Find with
#   bluetoothctl scan on
# GOES INTO: pi/badabing-music.env (BT_SPEAKER_MAC)
BT_SPEAKER_MAC=AA:BB:CC:DD:EE:FF

# Friendly speaker name (log lines only).
# GOES INTO: pi/badabing-music.env (BT_SPEAKER_NAME)
BT_SPEAKER_NAME=BadaBing Speaker

# Bluetooth controller (hciX). With the recommended USB dongle + disable-bt it is
# hci0; verify with `bluetoothctl list`.
# GOES INTO: pi/badabing-music.env (BT_CONTROLLER)
BT_CONTROLLER=hci0


# -----------------------------------------------------------------------------
# Battery telemetry via INA219  (OPTIONAL — only the --battery Pi install)
# -----------------------------------------------------------------------------

# Master switch. 1 enables I2C reads + battery fields in status.json.
# GOES INTO: pi/badabing-status.env (BATTERY_ENABLE)
BATTERY_ENABLE=0

# I2C bus + 7-bit address of the INA219.
# GOES INTO: pi/badabing-status.env (INA219_BUS, INA219_ADDR)
INA219_BUS=1
INA219_ADDR=0x40

# Pack voltage window for the rough state-of-charge % (TUNE to your pack).
# GOES INTO: pi/badabing-status.env (BATT_FULL_V, BATT_EMPTY_V)
BATT_FULL_V=13.4
BATT_EMPTY_V=12.0
